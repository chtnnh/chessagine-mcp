{
  "name": "chessagine-mcp",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "build/runner/stdio.js",
  "bin": "build/runner/stdio.js",
  "exports": {
    ".": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    }
  },
  "scripts": {
    "build:vercel": "tsc && tsc && chmod +x build/runner/remote.js",
    "build:mcp": "tsc && chmod +x build/runner/stdio.js && mcpb pack",
    "build:ui": "npm run build:chess-board && npm run build:pgn-viewer",
    "build:chess-board": "BUILD_APP=chess-board vite build",
    "build:pgn-viewer": "BUILD_APP=pgn-viewer vite build",
    "build": "npm run build:ui && npm run build:mcp",
    "publish": "npm run clean && npm run build",
    "debug": "npx @modelcontextprotocol/inspector node build/runner/stdio.js",
    "start": "node build/runner/stdio.js",
    "remote": "node build/runner/remote.js",
    "clean": "rm -rf build dist",
    "hardclean": "rm -rf node_modules"
  },
  "keywords": [],
  "author": "Jalp",
  "license": "MIT & GPL",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@jalpp/mcp-adapter": "^0.3.1",
    "@mliebelt/pgn-viewer": "^1.6.11",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@vitejs/plugin-react": "^5.2.0",
    "axios": "^1.13.5",
    "chess.js": "^1.4.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mcp-handler": "^1.0.7",
    "react": "^19.2.4",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.4",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "void57-chess": "^1.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
